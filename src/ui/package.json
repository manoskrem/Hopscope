{
  "name": "hopscope-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hopscope — real-time visual event-stream debugger UI",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
