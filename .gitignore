# ---- .NET ----
bin/
obj/
artifacts/
*.user
*.suo
[Pp]ublish/
*.binlog

# ---- Node / UI ----
node_modules/
.next/
dist/
build/
*.tsbuildinfo

# ---- Go (agent) ----
/src/agent/**/*.test
/src/agent/bin/
# eBPF: redis.bpf.c + vmlinux_min.h are committed, but the bpf2go output (the CO-RE object
# files and the Go loader wrappers) is regenerated by `go generate` in the Docker build — never
# committed (binary blobs / host-specific). Keep gen.go + the .c/.h sources tracked.
/src/agent/internal/bpf/*.o
/src/agent/internal/bpf/bpf_bpf*.go

# ---- Generated protobuf (regenerated from contracts/proto) ----
**/*.pb.go
**/Generated/*.cs
# Exception: the Go agent's gRPC bindings ARE committed (so `go build` works without protoc and
# the wire shape stays reviewable). Generated from contracts/proto/event.proto — see contracts/README.md.
!/src/agent/internal/contracts/v1/*.pb.go

# ---- Env / secrets ----
.env
.env.*
!.env.example

# ---- OS / IDE ----
.DS_Store
.vs/
.vscode/
.idea/
*.swp
